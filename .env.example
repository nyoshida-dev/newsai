SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL=random
SLACK_EXCLUDE_CHANNELS=foo,bar
# provider=api の場合のみ必須（base_url を変える場合は config.toml の api_key_env をキー名に合わせる）
OPENAI_API_KEY=sk-...
# 任意: config.toml の値を上書き
# LLM_PROVIDER=claude        # api | codex | claude | opencode
# LLM_MODEL=
# LLM_BASE_URL=
# provider=claude を CI で使う場合: `claude setup-token` の出力
# CLAUDE_CODE_OAUTH_TOKEN=
